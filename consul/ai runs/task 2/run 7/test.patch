+
+package structs
+
+import "testing"
+
+func TestFileSystemCertificate__HABITAT(t *testing.T) {
+	t.Parallel()
+
+	cases := map[string]configEntryTestcase{
+		"valid file system certificate": {
+			entry: &FileSystemCertificateConfigEntry{
+				Kind:        FileSystemCertificate,
+				Name:        "cert-one",
+				Certificate: "/path/to/certificate.crt",
+				PrivateKey:  "/path/to/private.key",
+			},
+		},
+		"file system certificate with meta": {
+			entry: &FileSystemCertificateConfigEntry{
+				Kind:        FileSystemCertificate,
+				Name:        "cert-two",
+				Certificate: "/opt/consul/tls/cert.pem",
+				PrivateKey:  "/opt/consul/tls/key.pem",
+				Meta:        map[string]string{"foo": "bar"},
+			},
+		},
+		"file system certificate with empty paths": {
+			entry: &FileSystemCertificateConfigEntry{
+				Kind: FileSystemCertificate,
+				Name: "cert-three",
+			},
+		},
+	}
+	testConfigEntryNormalizeAndValidate(t, cases)
+}
