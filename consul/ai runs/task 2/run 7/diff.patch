+// Copyright (c) HashiCorp, Inc.
+// SPDX-License-Identifier: BUSL-1.1
+
+package structs
+
+import "testing"
+
+func TestFileSystemCertificate(t *testing.T) {
+	t.Parallel()
+
+	cases := map[string]configEntryTestcase{
+		"valid with file paths": {
+			entry: &FileSystemCertificateConfigEntry{
+				Kind:        FileSystemCertificate,
+				Name:        "cert-one",
+				Certificate: "/opt/consul/tls/api-gateway.crt",
+				PrivateKey:  "/opt/consul/tls/api-gateway.key",
+			},
+		},
+		"valid with metadata": {
+			entry: &FileSystemCertificateConfigEntry{
+				Kind:        FileSystemCertificate,
+				Name:        "cert-two",
+				Certificate: "/path/to/cert.pem",
+				PrivateKey:  "/path/to/key.pem",
+				Meta: map[string]string{
+					"env": "production",
+				},
+			},
+		},
+		"valid with empty paths": {
+			entry: &FileSystemCertificateConfigEntry{
+				Kind:        FileSystemCertificate,
+				Name:        "cert-three",
+				Certificate: "",
+				PrivateKey:  "",
+			},
+		},
+	}
+	testConfigEntryNormalizeAndValidate(t, cases)
+}
