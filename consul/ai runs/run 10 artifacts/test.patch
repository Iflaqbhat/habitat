+// Test that session health check status and output are updated when session is created and destroyed
+func TestHealthCheck_Session__HABITAT(t *testing.T) {
+	s := testStateStore(t)
+
+	var check *structs.HealthCheck
+	// setup node
+	testRegisterNode(t, s, 1, "foo-node")
+	testRegisterCheckCustom__HABITAT(t, s, 1, "foo", func(chk *structs.HealthCheck) {
+		chk.Node = "foo-node"
+		chk.Type = "session"
+		chk.Status = api.HealthCritical
+		chk.Definition = structs.HealthCheckDefinition{
+			SessionName: "test-session",
+		}
+		check = chk
+	})
+
+	// Ensure the index was not updated if nothing was destroyed.
+	if idx := s.maxIndex("sessions"); idx != 0 {
+		t.Fatalf("bad index: %d", idx)
+	}
+
+	// Register a new session
+	sess := &structs.Session{
+		ID:   testUUID(),
+		Node: "foo-node",
+		Name: "test-session",
+	}
+	// assert the check is critical initially
+	assertHealthCheckStatusAndOutput__HABITAT(t, s, sess, check.CheckID, api.HealthCritical, "")
+
+	if err := s.SessionCreate(2, sess); err != nil {
+		t.Fatalf("The system shall allow session to be created ignoring the session check is critical. err: %s", err)
+	}
+	// assert the check is passing after session creation with correct output
+	expectedOutput := "Session '" + sess.ID + "' in force"
+	assertHealthCheckStatusAndOutput__HABITAT(t, s, sess, check.CheckID, api.HealthPassing, expectedOutput)
+
+	// Destroy the session.
+	if err := s.SessionDestroy(3, sess.ID, nil); err != nil {
+		t.Fatalf("err: %s", err)
+	}
+	// assert the check is critical after session destroy with correct output
+	expectedOutputInvalid := "Session '" + sess.ID + "' is invalid"
+	assertHealthCheckStatusAndOutput__HABITAT(t, s, sess, check.CheckID, api.HealthCritical, expectedOutputInvalid)
+}
