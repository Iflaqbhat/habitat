+// Test that session can be created and destroyed successfully when no matching health checks exist
+func TestHealthCheck_SessionNoMatchingChecks__HABITAT(t *testing.T) {
+	s := testStateStore(t)
+
+	// setup node
+	testRegisterNode(t, s, 1, "foo-node")
+
+	// Register a new session with no matching health checks
+	sess := &structs.Session{
+		ID:   testUUID(),
+		Node: "foo-node",
+		Name: "test-session",
+	}
+
+	// Session creation should succeed even when no matching checks exist
+	if err := s.SessionCreate(2, sess); err != nil {
+		t.Fatalf("Session creation should succeed when no matching checks exist. err: %s", err)
+	}
+
+	// Session destruction should also succeed when no matching checks exist
+	if err := s.SessionDestroy(3, sess.ID, nil); err != nil {
+		t.Fatalf("Session destruction should succeed when no matching checks exist. err: %s", err)
+	}
+}
