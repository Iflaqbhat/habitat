+# Copyright: Contributors to the Ansible project
+# GNU General Public License v3.0+ (see COPYING or https://www.gnu.org/licenses/gpl-3.0.txt)
+
+from __future__ import annotations
+
+import os
+import shutil
+import subprocess
+import sys
+import tempfile
+
+
+def test_connection_propagation__HABITAT():
+    """Test that task.connection is properly propagated with resolved connection name."""
+    # Get the directory where this test file is located
+    test_dir = os.path.dirname(os.path.abspath(__file__))
+    playbook_path = os.path.join(test_dir, 'connection_name__HABITAT.yml')
+
+    # Find ansible-playbook - try multiple methods
+    ansible_playbook_cmd = None
+
+    # Method 1: Try to find in PATH
+    ansible_playbook = shutil.which('ansible-playbook')
+
+    # Method 2: Try to find in repo's bin directory
+    if not ansible_playbook:
+        repo_root = os.path.abspath(os.path.join(test_dir, '../../../../..'))
+        bin_path = os.path.join(repo_root, 'bin', 'ansible-playbook')
+        if os.path.exists(bin_path) and os.access(bin_path, os.X_OK):
+            ansible_playbook = bin_path
+
+    # Method 3: Use Python module (most reliable)
+    if ansible_playbook:
+        ansible_playbook_cmd = [ansible_playbook]
+    else:
+        # Use Python to run ansible-playbook as a module
+        ansible_playbook_cmd = [sys.executable, '-m', 'ansible.cli.playbook']
+
+    # Create a temporary file for output
+    with tempfile.NamedTemporaryFile(mode='w', delete=False, suffix='.out') as outfile:
+        outfile_path = outfile.name
+
+    try:
+        # Run ansible-playbook with the callback enabled
+        env = os.environ.copy()
+        env['ANSIBLE_CALLBACKS_ENABLED'] = 'track_connections__HABITAT'
+
+        cmd = ansible_playbook_cmd + [
+            playbook_path,
+            '-i', 'localhost,'
+        ]
+
+        # Run the playbook and capture output
+        result = subprocess.run(
+            cmd,
+            cwd=test_dir,
+            env=env,
+            capture_output=True,
+            text=True,
+            check=False
+        )
+
+        # Write output to file for grep
+        with open(outfile_path, 'w') as f:
+            f.write(result.stdout)
+            f.write(result.stderr)
+
+        # Check that the expected message is in the output
+        output = result.stdout + result.stderr
+        assert 'FOUND EXPECTED EVENTS' in output, (
+            f"Expected 'FOUND EXPECTED EVENTS' not found in output.\n"
+            f"Return code: {result.returncode}\n"
+            f"Stdout: {result.stdout}\n"
+            f"Stderr: {result.stderr}"
+        )
+
+    finally:
+        # Clean up temp file
+        if os.path.exists(outfile_path):
+            os.unlink(outfile_path)
